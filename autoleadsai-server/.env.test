# ─── Server ──────────────────────────────────────────
PORT=3001
NODE_ENV=test

# ─── Database ────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/autoleadsai_test
REDIS_URL=redis://localhost:6379/1

# ─── JWT ─────────────────────────────────────────────
JWT_SECRET=test-jwt-secret-do-not-use-in-production
JWT_REFRESH_SECRET=test-refresh-secret-do-not-use-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Paddle (Billing) ────────────────────────────────
PADDLE_API_KEY=test_paddle_api_key
PADDLE_WEBHOOK_SECRET=test_paddle_webhook_secret
PADDLE_SANDBOX=true

# ─── n8n ─────────────────────────────────────────────
N8N_API_URL=http://localhost:5678
N8N_WEBHOOK_BASE=http://localhost:5678/webhook

# ─── Email (SMTP) ────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@autoleadsai-test.com
EMAIL_FROM_NAME=AutoLeads AI Test

# ─── Slack ───────────────────────────────────────────
SLACK_CLIENT_ID=test_slack_client_id
SLACK_CLIENT_SECRET=test_slack_client_secret
SLACK_SIGNING_SECRET=test_slack_signing_secret

# ─── App URLs ────────────────────────────────────────
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:3001

# ─── Logging ─────────────────────────────────────────
LOG_LEVEL=error

# ─── Rate Limiting ───────────────────────────────────
RATE_LIMIT_WINDOW_MS=1000
RATE_LIMIT_MAX=1000